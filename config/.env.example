# ===========================================================================
# 🤖 PROVEEDORES DE LLM (APIs Nube)
# ===========================================================================

# --- DeepSeek ---
# Obtén tu clave en: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-v4-flash

# --- Google Gemini ---
# Clave principal (soporta claves secundarias para round-robin y evitar 429)
# GEMINI_API_KEY=AIzaSy...
# GEMINI_API_KEY_2=AIzaSy...
# GEMINI_API_KEY_3=AIzaSy...
# GEMINI_API_KEY_4=AIzaSy...
# GEMINI_API_KEY_5=AIzaSy...
# GEMINI_MODEL=gemini-2.5-flash

# --- GitHub Models (Gratuito para desarrolladores) ---
# Token de GitHub para usar modelos como gpt-4o de forma gratuita
# GITHUB_GPT4O_TOKEN=ghp_...
# GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference
# GITHUB_GPT4O_MODEL=gpt-4o

# --- Cerebras Cloud ---
# Inferencia ultrarrápida (soporta round-robin)
# CEREBRAS_API_KEY=csk-...
# CEREBRAS_API_KEY_2=csk-...
# CEREBRAS_API_KEY_3=csk-...

# --- Groq Cloud ---
# GROQ_API_KEY=gsk_...

# --- OpenRouter ---
# OPENROUTER_API_KEY=sk-or-...

# ===========================================================================
# 💻 MODELOS LOCALES (Ollama / Llama.cpp)
# ===========================================================================

# --- Ollama ---
# OLLAMA_API_KEY= (Opcional, solo si usas Ollama en la nube)
# OLLAMA_ENDPOINT=http://localhost:11434/v1/chat/completions
# OLLAMA_MODEL=gemma3:12b
# OLLAMA_MODEL_PLANNER=gemma3:12b
# OLLAMA_MODEL_JUDGE=gemma3:12b
# OLLAMA_MODEL_FAST=gemma3:12b
# OLLAMA_AUTO_PULL=False
# OLLAMA_STAGE4_CONCURRENCY=100

# --- Extractor Local GGUF (Llama.cpp) ---
# ENABLE_LOCAL_EXTRACTOR=True
# LOCAL_EXTRACTOR_PATH=models/qwen2.5-3b-instruct-q4_k_m.gguf

# ===========================================================================
# 📚 APIS ACADÉMICAS Y TRADUCCIÓN
# ===========================================================================

# --- Semantic Scholar ---
# Recomendado para búsquedas sin límites estrictos de tasa
# SEMANTIC_SCHOLAR_API_KEY=...

# --- Unpaywall / CrossRef Polite ---
# Email de contacto para el agente de consulta respetuoso (Polite Agent)
# ACADEMIC_EMAIL=info@prisma-assistant.edu

# --- DeepL (Traducción de Criterios y Queries) ---
# DEEPL_API_KEY=...
# DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# --- Redalyc ---
# REDALYC_API_KEY=...

# ===========================================================================
# 🧠 EMBEDDINGS Y BASE DE DATOS VECTORIAL (ChromaDB / Milvus config)
# ===========================================================================

# --- Hugging Face ---
# Token para descargar modelos Sentence Transformers si es requerido
# HUGGINGFACE_API_KEY=hf_...

# --- Voyage AI (Embeddings alternativos) ---
# VOYAGE_API_KEY=pa-...

# --- Configuración del Modelo de Embeddings ---
# Opciones de Embeddings con Ollama (nomic-embed-text)
# USE_OLLAMA_EMBEDDING=True
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434

# Opciones de Embeddings Offline (Sentence-Transformers)
# EMBEDDING_MODEL=sentence-transformers/allenai-specter
# EMBEDDING_DIM=768

# Nombre de la colección en ChromaDB (o Milvus históricamente)
# MILVUS_COLLECTION=articles_collection_v8_specter

# ===========================================================================
# 💾 PERSISTENCIA DE SESIONES (MongoDB Atlas)
# ===========================================================================
# ENABLE_MONGODB=False
# MONGODB_URI=mongodb+srv://...

# ===========================================================================
# 🔒 SEGURIDAD Y EVALUACIÓN INTERNA
# ===========================================================================
# ENABLE_INTERNAL_EVALUATION=False
# INTERNAL_EVALUATION_TOKEN=...
