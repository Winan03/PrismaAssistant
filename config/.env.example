# ==========================================
# 🤖 DEEPSEEK V4 FLASH — PROVIDER PRIORITARIO
# ==========================================
# Obtén tu clave en: https://platform.deepseek.com/api_keys
# Modelo por defecto: deepseek-v4-flash
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-v4-flash

# Google Gemini
# GEMINI_API_KEY=...

# Ollama (local o cloud)
# OLLAMA_API_KEY=... (opcional, solo si usas Ollama Cloud)
# OLLAMA_ENDPOINT=http://localhost:11434/v1/chat/completions

# Cerebras
# CEREBRAS_API_KEY=...

# Groq
# GROQ_API_KEY=...

# OpenRouter
# OPENROUTER_API_KEY=...

# Semantic Scholar
# SEMANTIC_SCHOLAR_API_KEY=...

# Internal Evaluation Token (para /evaluation)
# ENABLE_INTERNAL_EVALUATION=False
# INTERNAL_EVALUATION_TOKEN=...
